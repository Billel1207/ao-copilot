# ══════════════════════════════════════════════════════════════════
# AO Copilot — Variables d'environnement PRODUCTION
# Copier ce fichier en .env.production et remplir toutes les valeurs
# NE JAMAIS commiter .env.production dans Git !
# ══════════════════════════════════════════════════════════════════

# ─── APP ──────────────────────────────────────────────────────────
APP_ENV=production
SECRET_KEY=GENERER_AVEC_openssl_rand_-hex_32
ALLOWED_ORIGINS=https://ao-copilot.fr,https://www.ao-copilot.fr
DOMAIN=ao-copilot.fr

# ─── DATABASE ─────────────────────────────────────────────────────
POSTGRES_USER=aocopilot
POSTGRES_PASSWORD=MOT_DE_PASSE_DB_TRES_FORT
POSTGRES_DB=aocopilot
DATABASE_URL=postgresql+asyncpg://aocopilot:MOT_DE_PASSE_DB_TRES_FORT@postgres:5432/aocopilot
DATABASE_URL_SYNC=postgresql://aocopilot:MOT_DE_PASSE_DB_TRES_FORT@postgres:5432/aocopilot

# ─── REDIS ────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ─── S3 SCALEWAY (Paris PAR1 — stockage documents) ───────────────
S3_ENDPOINT_URL=https://s3.fr-par.scw.cloud
S3_ACCESS_KEY=SCALEWAY_ACCESS_KEY_ID
S3_SECRET_KEY=SCALEWAY_SECRET_ACCESS_KEY
S3_BUCKET_NAME=aocopilot-documents
S3_REGION=fr-par
S3_SIGNED_URL_EXPIRY=900

# ─── IA — Anthropic Claude (moteur principal) ────────────────────
ANTHROPIC_API_KEY=sk-ant-VOTRE_CLE_ANTHROPIC
LLM_MODEL=claude-sonnet-4-6
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=16384

# ─── IA — Fallback GPT-4o (activé si OPENAI_API_KEY renseigné) ──
LLM_FALLBACK_MODEL=gpt-4o
OPENAI_API_KEY=sk-proj-VOTRE_CLE_OPENAI

# ─── Embeddings — OpenAI (défaut) ou Mistral (EU/RGPD) ──────────
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMS=1536

# ─── Mistral (hébergé en France — RGPD natif, optionnel) ────────
# Décommenter et renseigner pour utiliser Mistral au lieu d'OpenAI
# EMBEDDING_PROVIDER=mistral
MISTRAL_API_KEY=
MISTRAL_EMBEDDING_MODEL=mistral-embed

# ─── JWT — RS256 recommandé en production ────────────────────────
# Générer : openssl genrsa -out private.pem 2048
#           openssl rsa -in private.pem -pubout -out public.pem
# Puis copier le contenu PEM ici (sur une ligne avec \n entre les lignes)
JWT_ALGORITHM=RS256
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── PDF Renderer ────────────────────────────────────────────────
# true = WeasyPrint (CSS3 complet, nécessite deps système)
# false = xhtml2pdf (léger, défaut)
USE_WEASYPRINT=false

# ─── STRIPE (LIVE MODE) ─────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_VOTRE_CLE_STRIPE
STRIPE_PUBLISHABLE_KEY=pk_live_VOTRE_CLE_PUBLIQUE_STRIPE
STRIPE_WEBHOOK_SECRET=whsec_VOTRE_WEBHOOK_SECRET
STRIPE_PRICE_STARTER=price_1T9JtH01CSvduw4lzqagkbQQ
STRIPE_PRICE_PRO=price_1T9Jv901CSvduw4lh0rVDHiQ
STRIPE_PRICE_EUROPE=price_1T91vb01CSvduw4lFd3RvNL6
STRIPE_PRICE_BUSINESS=price_1T9Fum01CSvduw4lo5gFEIbE
STRIPE_PRICE_DOC_UNIT=price_1T9FwV01CSvduw4l4597ixbb

# ─── EMAILS (Resend) ────────────────────────────────────────────
RESEND_API_KEY=re_VOTRE_CLE_RESEND
EMAIL_FROM=noreply@ao-copilot.fr
FRONTEND_URL=https://ao-copilot.fr

# ─── e-Attestations (vérification conformité entreprises) ────────
EATTESTATION_API_KEY=
EATTESTATION_BASE_URL=https://api.e-attestations.com/v2

# ─── SENTRY (monitoring erreurs) ────────────────────────────────
SENTRY_DSN=

# ─── FRONTEND (Next.js) ─────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://ao-copilot.fr/api/v1
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_VOTRE_CLE_PUBLIQUE_STRIPE
