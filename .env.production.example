# ══════════════════════════════════════════════════════════════════
# AO Copilot — Variables d'environnement PRODUCTION
# Copier ce fichier en .env.production et remplir toutes les valeurs
# NE JAMAIS commiter .env.production dans Git !
# ══════════════════════════════════════════════════════════════════

# ─── APP ──────────────────────────────────────────────────────────
APP_ENV=production
SECRET_KEY=GENERER_AVEC_openssl_rand_-hex_32
ALLOWED_ORIGINS=https://ao-copilot.fr,https://www.ao-copilot.fr
DOMAIN=ao-copilot.fr

# ─── DATABASE ─────────────────────────────────────────────────────
POSTGRES_USER=aocopilot
POSTGRES_PASSWORD=MOT_DE_PASSE_DB_TRES_FORT
POSTGRES_DB=aocopilot
DATABASE_URL=postgresql+asyncpg://aocopilot:MOT_DE_PASSE_DB_TRES_FORT@postgres:5432/aocopilot
DATABASE_URL_SYNC=postgresql://aocopilot:MOT_DE_PASSE_DB_TRES_FORT@postgres:5432/aocopilot

# ─── REDIS ────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ─── S3 SCALEWAY (Paris PAR1) ─────────────────────────────────────
S3_ENDPOINT_URL=https://s3.fr-par.scw.cloud
S3_ACCESS_KEY=SCALEWAY_ACCESS_KEY_ID
S3_SECRET_KEY=SCALEWAY_SECRET_ACCESS_KEY
S3_BUCKET_NAME=aocopilot-documents
S3_REGION=fr-par
S3_SIGNED_URL_EXPIRY=900

# ─── IA — Anthropic Claude ────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-VOTRE_CLE_ANTHROPIC
LLM_MODEL=claude-sonnet-4-6
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=16384

# ─── IA — OpenAI Embeddings ───────────────────────────────────────
OPENAI_API_KEY=sk-proj-VOTRE_CLE_OPENAI
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMS=1536

# ─── JWT ──────────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── STRIPE (LIVE MODE) ───────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_VOTRE_CLE_STRIPE
STRIPE_PUBLISHABLE_KEY=pk_live_VOTRE_CLE_PUBLIQUE_STRIPE
STRIPE_WEBHOOK_SECRET=whsec_VOTRE_WEBHOOK_SECRET
STRIPE_PRICE_STARTER=price_VOTRE_PRICE_STARTER
STRIPE_PRICE_PRO=price_VOTRE_PRICE_PRO
STRIPE_PRICE_EUROPE=price_VOTRE_PRICE_EUROPE

# ─── EMAILS (Resend) ──────────────────────────────────────────────
RESEND_API_KEY=re_VOTRE_CLE_RESEND
EMAIL_FROM=noreply@ao-copilot.fr
FRONTEND_URL=https://ao-copilot.fr

# ─── SENTRY (optionnel) ───────────────────────────────────────────
SENTRY_DSN=

# ─── FRONTEND (Next.js) ───────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://ao-copilot.fr/api/v1
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_VOTRE_CLE_PUBLIQUE_STRIPE
