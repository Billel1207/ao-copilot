# ─── APP ──────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change-me-in-production-min-32-chars
ALLOWED_ORIGINS=http://localhost:3000

# ─── DATABASE ─────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://aocopilot:aocopilot_secret@localhost:5432/aocopilot
DATABASE_URL_SYNC=postgresql://aocopilot:aocopilot_secret@localhost:5432/aocopilot

# ─── REDIS ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ─── S3 / MINIO ───────────────────────────────────────
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=aocopilot_minio
S3_SECRET_KEY=aocopilot_minio_secret
S3_BUCKET_NAME=aocopilot-documents
S3_REGION=fr-par
S3_SIGNED_URL_EXPIRY=900   # 15 minutes

# ─── LLM (Anthropic Claude — moteur IA principal) ─────
ANTHROPIC_API_KEY=sk-ant-...
LLM_MODEL=claude-sonnet-4-6
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096

# ─── EMBEDDINGS (OpenAI — vecteurs uniquement) ───────
OPENAI_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMS=1536

# ─── JWT ──────────────────────────────────────────────
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── SENTRY (optionnel) ───────────────────────────────
SENTRY_DSN=

# ─── FRONTEND (Next.js) ───────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
