# ═══════════════════════════════════════════════════════════════════════════════
# AO Copilot — Environment Variables
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════════════════════

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development                    # development | staging | production
SECRET_KEY=change-me-in-production-min-32-chars   # REQUIRED in production: random 64-char string
ALLOWED_ORIGINS=http://localhost:3000   # Comma-separated list of allowed CORS origins

# ── Database (PostgreSQL 16 + pgvector) ───────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://aocopilot:aocopilot_secret@localhost:5432/aocopilot
DATABASE_URL_SYNC=postgresql://aocopilot:aocopilot_secret@localhost:5432/aocopilot

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── S3 Storage (Scaleway Object Storage or MinIO for dev) ─────────────────────
S3_ENDPOINT_URL=http://localhost:9000  # Scaleway: https://s3.fr-par.scw.cloud
S3_ACCESS_KEY=your_s3_access_key
S3_SECRET_KEY=your_s3_secret_key
S3_BUCKET_NAME=aocopilot-documents
S3_REGION=fr-par
S3_SIGNED_URL_EXPIRY=900               # Signed URL expiry in seconds (15 min)

# ── LLM — Anthropic Claude (main AI engine) ──────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxx           # REQUIRED: your Anthropic API key
LLM_MODEL=claude-sonnet-4-6
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096

# ── LLM Fallback — OpenAI GPT-4o (automatic when Anthropic is down) ─────────
LLM_FALLBACK_MODEL=gpt-4o             # Used automatically if Anthropic API fails

# ── Embeddings — OpenAI (default) or Mistral (EU RGPD) ──────────────────────
OPENAI_API_KEY=sk-xxx                  # REQUIRED: for embeddings + LLM fallback
EMBEDDING_PROVIDER=openai              # "openai" (default) or "mistral" (EU RGPD)

# ── Mistral (optional — EU-hosted embeddings for RGPD compliance) ───────────
MISTRAL_API_KEY=                       # Optional: for mistral-embed (hosted in France)
MISTRAL_EMBEDDING_MODEL=mistral-embed  # Mistral embedding model
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMS=1536

# ── JWT Authentication ────────────────────────────────────────────────────────
JWT_ALGORITHM=HS256                    # HS256 (dev) or RS256 (production recommended)
JWT_PRIVATE_KEY=                       # PEM RSA private key (required for RS256)
JWT_PUBLIC_KEY=                        # PEM RSA public key (required for RS256)
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── PDF Renderer ────────────────────────────────────────────────────────────
USE_WEASYPRINT=false                   # true to use WeasyPrint (better CSS3, needs system deps)

# ── Sentry (error monitoring) ────────────────────────────────────────────────
SENTRY_DSN=                            # Optional: https://xxx@sentry.io/xxx

# ── Stripe Billing ───────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxx          # REQUIRED for billing
STRIPE_WEBHOOK_SECRET=whsec_xxx        # From Stripe webhook dashboard
STRIPE_PUBLISHABLE_KEY=pk_test_xxx     # For frontend (not secret)
STRIPE_PRICE_STARTER=price_xxx         # Starter plan (69 EUR/month)
STRIPE_PRICE_PRO=price_xxx             # Pro plan (179 EUR/month)
STRIPE_PRICE_EUROPE=price_xxx          # Europe plan (299 EUR/month)
STRIPE_PRICE_BUSINESS=price_xxx        # Business plan (499 EUR/month)
STRIPE_PRICE_DOC_UNIT=price_xxx        # Pay-per-doc (3 EUR/doc)

# ── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxx                  # Optional: for transactional emails
EMAIL_FROM=AO Copilot <noreply@ao-copilot.fr>
FRONTEND_URL=http://localhost:3000     # Used in emails and SSO callbacks

# ── e-Attestations.com ───────────────────────────────────────────────────────
EATTESTATION_API_KEY=                  # Optional: for DC verification
EATTESTATION_BASE_URL=https://api.e-attestations.com/v2
