# ─── Frontend AO Copilot (Next.js) ───────────────────────────
# Copier ce fichier en .env.local et ajuster les valeurs

# URL de l'API backend (sans slash final)
# Développement local :
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
API_URL=http://localhost:8000/api/v1

# Production (exemple) :
# NEXT_PUBLIC_API_URL=https://api.aocopilot.fr/api/v1
# API_URL=https://api.aocopilot.fr/api/v1

# ─── Support Chat (Tawk.to — 100% gratuit) ───────────────────
# Laisser vide pour désactiver le widget
# Obtenir l'ID : https://tawk.to → Settings → Chat Widget → Direct Chat Link
# Format : XXXXXXXXXXXXXXXXXXXXXXXX/XXXXXXXXXX
# NEXT_PUBLIC_TAWKTO_ID=
