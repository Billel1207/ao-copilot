{
  "version": "0.0.1",
  "autoPort": true,
  "configurations": [
    {
      "name": "frontend",
      "runtimeExecutable": "node",
      "runtimeArgs": ["apps/web/node_modules/next/dist/bin/next", "dev", "apps/web"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "backend",
      "runtimeExecutable": "node",
      "runtimeArgs": ["scripts/start-backend.mjs"],
      "port": 8000
    },
    {
      "name": "celery-worker",
      "runtimeExecutable": "node",
      "runtimeArgs": ["scripts/start-celery.mjs"],
      "port": 5555
    }
  ],
  "autoVerify": true
}
